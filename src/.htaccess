# MIME type fixes
# LiteSpeed compresses text/* by default but not application/json or binary types.
# Remap JSON to text/json so it gets compressed automatically.
AddType text/json .json
# Fix PBF MIME type so cache rules match (default: application/octet-stream)
AddType application/x-protobuf .pbf

# Apache fallback: enable gzip compression for text-based assets
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/json
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE application/x-protobuf
    AddOutputFilterByType DEFLATE font/ttf
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    # Content-hashed bundles: cache for 1 year (hash changes on content change)
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"
    # Data files: cache for 1 hour (updated by pipeline)
    ExpiresByType text/json "access plus 1 hour"
    ExpiresByType application/json "access plus 1 hour"
    # Fonts and glyphs: cache for 1 year
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/x-protobuf "access plus 1 year"
    # HTML: no cache (always serve fresh)
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>
